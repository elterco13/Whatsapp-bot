# Google Gemini AI API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google Sheets IDs
# Format: https://docs.google.com/spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEET_ID=your_main_spreadsheet_id
GOOGLE_SHEET_IDEAS_ID=your_ideas_sheet_id
GOOGLE_SHEET_RECIPES_ID=your_recipes_sheet_id

# Google Calendar ID
# Usually your email or calendar-specific ID
GOOGLE_CALENDAR_ID=your_calendar_id@gmail.com

# WhatsApp Chat Filtering (Optional)
# Comma-separated list of allowed chat IDs (groups or individual chats)
# Leave empty to allow all chats
# Format for groups: 120363XXXXXXXXX@g.us
# Format for individuals: 34XXXXXXXXX@s.whatsapp.net
ALLOWED_CHATS=

# Dashboard Port (Optional)
# Default: 3000
PORT=3000
